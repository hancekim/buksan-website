# Fassto FMS 크롤러 환경변수 예시
# 로컬에서 테스트할 때는 이 파일을 .env 로 복사해서 채우세요.
# (GitHub Actions 에서는 이 값들을 Repository Secrets 로 등록합니다.)

# --- 필수 ---
FASSTO_ID=여기에_아이디
FASSTO_PW=여기에_비밀번호

# --- 선택 (필요 시 주석 해제 후 지정) ---
# FASSTO_LOGIN_URL=https://fms.fassto.ai/classic/cmn/main/main.do
# FASSTO_MAIN_URL=https://fms.fassto.ai/classic/cmn/main/main.do

# 로그인 입력칸 자동탐지가 실패할 때만 직접 지정
# FASSTO_ID_SELECTOR=input[name='userId']
# FASSTO_PW_SELECTOR=input[name='userPw']
# FASSTO_SUBMIT_SELECTOR=button.login

# raw 응답을 확인해 "그 스프레드시트" 데이터를 주는 엔드포인트를 찾았다면 지정
# (URL 에 이 문자열이 포함된 응답만 target_payloads 로 모음)
# TARGET_API_KEYWORD=main/selectMainList

# 출력 폴더 / 디버깅
# OUTPUT_DIR=data
# HEADLESS=true
